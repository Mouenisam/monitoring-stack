# =================================================================
# Configuration de la stack de test de charge
# Copie ce fichier en .env et adapte les valeurs à ton contexte :
#   cp .env.example .env
# =================================================================

# --- Cible du test de charge ---
# URL de base de l'application à tester
# Exemple : https://mon-appli.com
BASE_URL=https://petstore.octoperf.com

# --- Grafana ---
# Identifiants d'accès à l'interface Grafana (http://localhost:3000)
# Change le mot de passe pour un usage en équipe ou en démo
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# --- Versions des images Docker ---
# Épingle des versions précises pour la reproductibilité
PROMETHEUS_VERSION=v3.1.0
GRAFANA_VERSION=11.4.0
K6_VERSION=0.55.0
